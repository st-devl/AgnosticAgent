  "description": "Merkezi kontrat registry. T\u00fcm API kontratlar\u0131 burada indekslenir.",
  "contracts": {},
  "domains": {},
  "_usage": {
    "how_to_add": "Yeni kontrat olu\u015fturuldu\u011funda bu dosya otomatik g\u00fcncellenir",
    "structure": {
      "contracts": {
        "{operation_name}": {
          "domain": "string",
          "entity": "string",
          "versions": {
            "v{version}": {
              "status": "stable|beta|deprecated",
              "path": "contracts/{domain}/{entity}/v{version}",
              "created_at": "ISO 8601 date",
              "deprecated": false,
              "sunset_date": "ISO 8601 date (e\u011fer deprecated ise)"
            }
          },
          "latest_stable": "v{version}",
          "latest_beta": "v{version}"
        }
      },
      "domains": {
        "{domain_name}": {
          "description": "string",
          "entities": [
            "entity1",
            "entity2"
          ]
        }
      }
    }
  }
