{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "registry-schema.json",
    "title": "Contract Registry Schema",
    "description": "Merkezi kontrat registry dosyasının şeması",
    "type": "object",
    "required": [
        "version",
        "contracts",
        "domains"
    ],
    "properties": {
        "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Registry şema versiyonu (semver)"
        },
        "last_updated": {
            "type": "string",
            "format": "date-time",
            "description": "Son güncelleme tarihi (ISO 8601)"
        },
        "description": {
            "type": "string",
            "description": "Registry açıklaması"
        },
        "contracts": {
            "type": "object",
            "description": "Tüm kontratların listesi",
            "additionalProperties": {
                "$ref": "#/definitions/contract_entry"
            }
        },
        "domains": {
            "type": "object",
            "description": "Domain tanımları",
            "additionalProperties": {
                "$ref": "#/definitions/domain_entry"
            }
        }
    },
    "definitions": {
        "contract_entry": {
            "type": "object",
            "required": [
                "domain",
                "entity",
                "versions",
                "latest_stable"
            ],
            "properties": {
                "domain": {
                    "type": "string",
                    "description": "Kontratın ait olduğu domain"
                },
                "entity": {
                    "type": "string",
                    "description": "Kontratın ait olduğu entity"
                },
                "versions": {
                    "type": "object",
                    "description": "Kontrat versiyonları",
                    "additionalProperties": {
                        "$ref": "#/definitions/version_entry"
                    }
                },
                "latest_stable": {
                    "type": "string",
                    "pattern": "^v\\d+\\.\\d+\\.\\d+$",
                    "description": "En son stabil versiyon"
                },
                "latest_beta": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "pattern": "^v\\d+\\.\\d+\\.\\d+$",
                    "description": "En son beta versiyon (opsiyonel)"
                }
            }
        },
        "version_entry": {
            "type": "object",
            "required": [
                "status",
                "path",
                "created_at"
            ],
            "properties": {
                "status": {
                    "type": "string",
                    "enum": [
                        "stable",
                        "beta",
                        "deprecated"
                    ],
                    "description": "Versiyon durumu"
                },
                "path": {
                    "type": "string",
                    "description": "Kontrat dosya yolu"
                },
                "created_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Oluşturulma tarihi"
                },
                "deprecated": {
                    "type": "boolean",
                    "default": false,
                    "description": "Deprecated mi?"
                },
                "sunset_date": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "format": "date-time",
                    "description": "Kaldırılma tarihi (deprecated ise)"
                }
            }
        },
        "domain_entry": {
            "type": "object",
            "required": [
                "description",
                "entities"
            ],
            "properties": {
                "description": {
                    "type": "string",
                    "description": "Domain açıklaması"
                },
                "entities": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Domain'e ait entity'ler"
                }
            }
        }
    }
}